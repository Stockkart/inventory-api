{
  "verticalId": "medical",
  "version": "1.0.0",
  "entities": {
    "inventory": {
      "fields": [
        {
          "key": "name",
          "type": "string",
          "required": true,
          "storage": "core",
          "showIn": ["registration", "scan-sell"],
          "validation": { "minLength": 1, "maxLength": 255 }
        },
        {
          "key": "batchNo",
          "label": "Batch Number",
          "type": "string",
          "required": true,
          "storage": "extension",
          "indexed": true,
          "searchable": true,
          "showIn": ["registration", "scan-sell", "invoice"],
          "validation": { "minLength": 1, "maxLength": 64 }
        },
        {
          "key": "expiryDate",
          "label": "Expiry Date",
          "type": "date",
          "required": true,
          "storage": "extension",
          "indexed": true,
          "searchable": true,
          "sortable": true,
          "showIn": ["registration", "scan-sell", "reports", "basic"],
          "validation": { "notPastOnCreate": true }
        },
        {
          "key": "companyName",
          "label": "Company Name",
          "type": "string",
          "required": true,
          "storage": "core",
          "indexed": true,
          "showIn": ["registration", "basic"],
          "validation": { "maxLength": 200 }
        }
      ],
      "search": {
        "defaultSort": [
          { "field": "expiryDate", "direction": "asc", "nulls": "last" },
          { "field": "inventoryId", "direction": "asc" }
        ],
        "cursor": "compound-key"
      }
    },
    "shop": {
      "fields": [
        {
          "key": "dlNo",
          "label": "Drug License No (DL No)",
          "type": "string",
          "required": true,
          "storage": "core",
          "showIn": ["onboarding"],
          "validation": { "minLength": 1, "maxLength": 64 }
        },
        {
          "key": "fssai",
          "label": "FSSAI",
          "type": "string",
          "required": false,
          "storage": "core",
          "showIn": ["onboarding"],
          "validation": { "maxLength": 64 }
        }
      ]
    }
  }
}
