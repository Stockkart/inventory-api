<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty name="LOG_FILE" source="logging.file.name"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp": "%date{yyyy-MM-dd'T'HH:mm:ss.SSSZ}", "level": "%level", "thread": "%thread",
                "logger": "%logger", "message": "%msg", "traceId": "%mdc{traceId}", "pluginId": "%mdc{pluginId}",
                "exception": "%ex"}\n
            </pattern>
        </encoder>
    </appender>

    <logger name="com.inventory" level="DEBUG"/>
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.mongodb.driver" level="WARN"/>

    <if condition='isDefined("LOG_FILE")'>
        <then>
            <appender name="FILE_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <file>${LOG_FILE}</file>
                <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                    <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.gz</fileNamePattern>
                    <maxFileSize>50MB</maxFileSize>
                    <maxHistory>3</maxHistory>
                    <totalSizeCap>200MB</totalSizeCap>
                </rollingPolicy>
                <encoder>
                    <pattern>{"timestamp": "%date{yyyy-MM-dd'T'HH:mm:ss.SSSZ}", "level": "%level", "thread": "%thread",
                        "logger": "%logger", "message": "%msg", "traceId": "%mdc{traceId}", "pluginId": "%mdc{pluginId}",
                        "exception": "%ex"}\n
                    </pattern>
                </encoder>
            </appender>
            <root level="debug">
                <appender-ref ref="CONSOLE_JSON"/>
                <appender-ref ref="FILE_JSON"/>
            </root>
        </then>
        <else>
            <root level="debug">
                <appender-ref ref="CONSOLE_JSON"/>
            </root>
        </else>
    </if>
</configuration>
