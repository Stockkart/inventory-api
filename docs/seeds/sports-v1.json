{
  "verticalId": "sports",
  "version": "1.0.0",
  "taxRules": {
    "note": "Intrastate (same state): CGST + SGST. Interstate: IGST only — not both.",
    "intrastate": ["cgst", "sgst"],
    "interstate": ["igst"]
  },
  "entities": {
    "inventory": {
      "fields": [
        {
          "key": "name",
          "label": "Product",
          "type": "string",
          "required": true,
          "tier": "mandatory",
          "storage": "core",
          "showIn": ["registration", "scan-sell", "invoice"]
        },
        {
          "key": "hsn",
          "label": "HSN/SAC",
          "type": "string",
          "required": false,
          "tier": "regular",
          "storage": "core",
          "showIn": ["registration", "invoice"]
        },
        {
          "key": "baseUnit",
          "label": "Unit",
          "type": "string",
          "required": true,
          "tier": "mandatory",
          "storage": "core",
          "showIn": ["registration", "invoice"]
        },
        {
          "key": "sport",
          "label": "Sport",
          "type": "enum",
          "values": ["cricket", "football", "gym", "tennis", "badminton", "other"],
          "required": true,
          "tier": "mandatory",
          "storage": "extension",
          "indexed": true,
          "searchable": true,
          "showIn": ["registration", "scan-sell"]
        },
        {
          "key": "brand",
          "label": "Brand",
          "type": "string",
          "required": true,
          "tier": "mandatory",
          "storage": "extension",
          "indexed": true,
          "searchable": true,
          "showIn": ["registration", "scan-sell", "invoice"]
        },
        {
          "key": "model",
          "label": "Model",
          "type": "string",
          "required": true,
          "tier": "mandatory",
          "storage": "extension",
          "indexed": true,
          "showIn": ["registration", "scan-sell"]
        },
        {
          "key": "warrantyMonths",
          "label": "Warranty (months)",
          "type": "number",
          "required": false,
          "tier": "regular",
          "storage": "extension",
          "indexed": false,
          "showIn": ["registration"]
        }
      ]
    },
    "invoiceLine": {
      "fields": [
        {
          "key": "name",
          "label": "Products",
          "type": "string",
          "storage": "core",
          "showIn": ["invoice"]
        },
        {
          "key": "hsn",
          "label": "HSN/SAC",
          "type": "string",
          "storage": "core",
          "showIn": ["invoice"]
        },
        {
          "key": "qty",
          "label": "Qty",
          "type": "number",
          "storage": "core",
          "showIn": ["invoice"]
        },
        {
          "key": "baseUnit",
          "label": "Unit",
          "type": "string",
          "storage": "core",
          "showIn": ["invoice"]
        },
        {
          "key": "rate",
          "label": "Rate",
          "type": "money",
          "storage": "core",
          "showIn": ["invoice"]
        },
        {
          "key": "cgst",
          "label": "CGST",
          "type": "tax",
          "storage": "core",
          "applicableWhen": "intrastate",
          "showIn": ["invoice"]
        },
        {
          "key": "sgst",
          "label": "SGST",
          "type": "tax",
          "storage": "core",
          "applicableWhen": "intrastate",
          "showIn": ["invoice"]
        },
        {
          "key": "igst",
          "label": "IGST",
          "type": "tax",
          "storage": "core",
          "applicableWhen": "interstate",
          "showIn": ["invoice"]
        },
        {
          "key": "amount",
          "label": "Amount",
          "type": "money",
          "storage": "computed",
          "computed": true,
          "showIn": ["invoice"]
        }
      ]
    }
  }
}
